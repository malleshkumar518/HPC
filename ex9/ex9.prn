[23bcs120@mepcolinux ex9]$cat sum.c 
#include <stdio.h>
#include <stdlib.h>
#include <omp.h>
int main() {
    int r, c, k, sum = 0;
    printf("Enter rows and columns: ");
    scanf("%d %d", &r, &c);
    int **matrix = (int **)malloc(r * sizeof(int *));
    for (int i = 0; i < r; i++)
        matrix[i] = (int *)malloc(c * sizeof(int));
    printf("Enter matrix elements:\n");
    for (int i = 0; i < r; i++)
        for (int j = 0; j < c; j++)
            scanf("%d", &matrix[i][j]);
    printf("Enter value of k: ");
    scanf("%d", &k);
    #pragma omp parallel for reduction(+:sum)
    for (int i = 0; i < r; i++) {
        for (int j = 0; j < c; j++) {
            if (matrix[i][j] % k == 0) {
                sum += matrix[i][j];
            }
        }
    }
    printf("Sum of elements divisible by %d: %d\n", k, sum);
    for (int i = 0; i < r; i++) free(matrix[i]);
    free(matrix);
    return 0;
}

